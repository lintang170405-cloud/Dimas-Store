<!--DIMAS STORE — MODERN REDESIGN 2026-->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=Inter:wght@300;400;500;600;700&display=swap" />
<style>

:root {
  --ink: #0a0a0a;
  --ink-soft: #1a1a1a;
  --cream: #f5f0e8;
  --cream-dark: #ede8df;
  --white: #ffffff;
  --sage: #8aad7f;
  --sage-dark: #4a7040;
  --sage-pale: #eaf2e7;
  --orange: #ee4d2d;
  --wa: #25D366;
  --muted: #6b6b6b;
  --line: #e8e3dc;
  --font-display: 'Syne', system-ui, sans-serif;
  --font-body: 'Inter', system-ui, sans-serif;
  --r-sm: 14px;
  --r-md: 20px;
  --r-lg: 28px;
  --r-xl: 40px;
}

html { scroll-behavior: smooth; }

#ds-app, #ds-app * { box-sizing: border-box; margin: 0; padding: 0; }

#ds-app {
  font-family: var(--font-body);
  color: var(--ink);
  background: var(--cream);
  width: 100%;
  overflow-x: hidden;
}

#ds-app a { color: inherit; text-decoration: none; }
#ds-app img { max-width: 100%; display: block; }
#ds-app button { cursor: pointer; font-family: var(--font-body); }

.ds-wrap { width: min(1200px, calc(100% - 40px)); margin: 0 auto; }

/* ── HEADER ── */
.ds-header {
  position: sticky; top: 0; z-index: 80;
  background: rgba(245,240,232,.92);
  backdrop-filter: blur(20px);
  border-bottom: 1px solid var(--line);
}
.ds-header-in {
  height: 64px; display: flex; align-items: center;
  justify-content: space-between; gap: 16px;
}
.ds-logo {
  font-family: var(--font-display);
  font-size: 20px; font-weight: 800;
  letter-spacing: -.05em;
}
.ds-logo em { color: var(--sage-dark); font-style: normal; }
.ds-nav {
  display: none; gap: 28px;
  font-size: 13px; font-weight: 600;
  color: var(--muted); letter-spacing: .01em;
}
.ds-nav a:hover { color: var(--ink); }
.ds-header-btns { display: flex; gap: 8px; align-items: center; }
.ds-icon-btn {
  width: 38px; height: 38px; border-radius: 999px;
  border: 1px solid var(--line);
  background: var(--white);
  display: inline-flex; align-items: center; justify-content: center;
  color: var(--muted); font-size: 14px;
  transition: all .2s;
}
.ds-icon-btn:hover { border-color: var(--ink); color: var(--ink); }

/* ── BUTTONS ── */
.ds-btn {
  display: inline-flex; align-items: center; justify-content: center;
  gap: 8px; padding: 0 22px; min-height: 48px;
  border-radius: 999px; border: 0; font-size: 13px;
  font-weight: 700; font-family: var(--font-body);
  letter-spacing: .02em; transition: all .22s ease;
  white-space: nowrap;
}
.ds-btn-black { background: var(--ink); color: #fff; }
.ds-btn-black:hover { background: var(--ink-soft); transform: translateY(-1px); }
.ds-btn-outline { background: transparent; color: var(--ink); border: 1.5px solid var(--ink); }
.ds-btn-outline:hover { background: var(--ink); color: #fff; }
.ds-btn-shopee { background: var(--orange); color: #fff; box-shadow: 0 8px 24px rgba(238,77,45,.3); }
.ds-btn-shopee:hover { transform: translateY(-2px); box-shadow: 0 12px 32px rgba(238,77,45,.38); }
.ds-btn-wa { background: var(--wa); color: #fff; box-shadow: 0 8px 24px rgba(37,211,102,.28); }
.ds-btn-wa:hover { transform: translateY(-2px); }
.ds-btn-sage { background: var(--sage-pale); color: var(--sage-dark); border: 1.5px solid #c5dcc1; }
.ds-btn-sage:hover { background: var(--sage); color: #fff; border-color: var(--sage); }
.ds-btn-sm { min-height: 38px; padding: 0 16px; font-size: 12px; }

/* ── HERO ── */
.ds-hero {
  padding: 60px 0 0;
  background: var(--cream);
}
.ds-hero-inner {
  display: grid; grid-template-columns: 1fr;
  gap: 40px; align-items: end;
}
.ds-eyebrow {
  display: inline-flex; align-items: center; gap: 8px;
  padding: 7px 14px; border-radius: 999px;
  border: 1.5px solid #c5dcc1;
  background: var(--sage-pale);
  color: var(--sage-dark);
  font-size: 11px; font-weight: 700;
  letter-spacing: .06em; text-transform: uppercase;
  margin-bottom: 20px;
}
.ds-hero h1 {
  font-family: var(--font-display);
  font-size: clamp(48px, 11vw, 96px);
  font-weight: 800; line-height: .92;
  letter-spacing: -.05em;
}
.ds-hero h1 .accent { color: var(--sage-dark); }
.ds-hero h1 .outline {
  -webkit-text-stroke: 2px var(--ink);
  color: transparent;
}
.ds-hero-desc {
  margin-top: 24px; max-width: 500px;
  color: var(--muted); font-size: 15px; line-height: 1.8;
}
.ds-hero-ctas { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 28px; }
.ds-hero-stats {
  display: flex; gap: 28px; flex-wrap: wrap;
  margin-top: 40px; padding-top: 28px;
  border-top: 1px solid var(--line);
}
.ds-stat strong {
  display: block;
  font-family: var(--font-display);
  font-size: 26px; font-weight: 800;
  letter-spacing: -.04em;
}
.ds-stat span { font-size: 11px; color: var(--muted); font-weight: 600; letter-spacing: .03em; text-transform: uppercase; }

.ds-hero-img-wrap {
  position: relative;
  border-radius: var(--r-xl) var(--r-xl) 0 0;
  overflow: hidden;
  min-height: 360px;
  background: #1a1a1a;
}
.ds-hero-img-wrap img {
  width: 100%; height: 100%;
  min-height: 360px; object-fit: cover;
  filter: brightness(.85) saturate(.9);
}
.ds-hero-tag {
  position: absolute; top: 20px; left: 20px;
  background: rgba(255,255,255,.12);
  backdrop-filter: blur(12px);
  border: 1px solid rgba(255,255,255,.2);
  border-radius: 999px;
  color: #fff; padding: 8px 16px;
  font-size: 12px; font-weight: 600;
  letter-spacing: .03em;
}
.ds-hero-float {
  position: absolute; bottom: 20px; left: 20px; right: 20px;
  background: rgba(255,255,255,.1);
  backdrop-filter: blur(20px);
  border: 1px solid rgba(255,255,255,.18);
  border-radius: var(--r-md);
  padding: 16px;
  display: flex; align-items: center; gap: 14px;
}
.ds-hero-float-icon {
  width: 46px; height: 46px; border-radius: 14px;
  background: var(--orange); color: #fff;
  display: flex; align-items: center; justify-content: center;
  font-size: 18px; flex: 0 0 auto;
}
.ds-hero-float h3 { color: #fff; font-size: 14px; font-weight: 700; margin-bottom: 3px; }
.ds-hero-float p { color: rgba(255,255,255,.72); font-size: 12px; line-height: 1.4; }

/* ── MARQUEE ── */
.ds-marquee-wrap {
  background: var(--ink); padding: 16px 0;
  overflow: hidden;
  margin-top: 60px;
}
.ds-marquee {
  display: flex; gap: 0; white-space: nowrap;
  animation: marquee 24s linear infinite;
}
.ds-marquee-track {
  display: flex; gap: 40px; padding-right: 40px;
  font-family: var(--font-display);
  font-size: 13px; font-weight: 700; letter-spacing: .08em;
  text-transform: uppercase; color: rgba(255,255,255,.55);
}
.ds-marquee-track .dot { color: var(--sage); }
@keyframes marquee { from { transform: translateX(0); } to { transform: translateX(-50%); } }

/* ── CATEGORY STRIP ── */
.ds-cat-section { padding: 64px 0; background: var(--cream); }
.ds-section-label {
  font-size: 11px; font-weight: 700; letter-spacing: .1em;
  text-transform: uppercase; color: var(--muted); margin-bottom: 16px;
}
.ds-section-title {
  font-family: var(--font-display);
  font-size: clamp(28px, 5vw, 44px);
  font-weight: 800; letter-spacing: -.04em;
  line-height: 1.05;
}
.ds-cat-scroll {
  display: flex; gap: 12px; overflow-x: auto;
  scroll-snap-type: x mandatory;
  padding: 24px 0 8px; scrollbar-width: none;
}
.ds-cat-scroll::-webkit-scrollbar { display: none; }
.ds-cat-item {
  flex: 0 0 auto; scroll-snap-align: start;
  width: 140px; text-align: center; cursor: pointer;
}
.ds-cat-img {
  width: 140px; height: 160px; border-radius: var(--r-md);
  overflow: hidden; background: #ddd; position: relative;
  border: 2px solid transparent;
  transition: all .25s;
}
.ds-cat-item:hover .ds-cat-img { border-color: var(--ink); transform: translateY(-3px); }
.ds-cat-img img { width: 100%; height: 100%; object-fit: cover; transition: transform .3s; }
.ds-cat-item:hover .ds-cat-img img { transform: scale(1.06); }
.ds-cat-name {
  margin-top: 10px; font-size: 12px; font-weight: 700;
  color: var(--ink); letter-spacing: .01em;
}

/* ── WHY US ── */
.ds-why-section {
  padding: 64px 0;
  background: var(--ink);
}
.ds-why-section .ds-section-label { color: rgba(255,255,255,.4); }
.ds-why-section .ds-section-title { color: #fff; }
.ds-why-grid {
  display: grid; grid-template-columns: repeat(2, 1fr);
  gap: 1px; background: rgba(255,255,255,.08);
  border: 1px solid rgba(255,255,255,.08);
  border-radius: var(--r-lg); overflow: hidden;
  margin-top: 40px;
}
.ds-why-card {
  background: var(--ink-soft);
  padding: 28px 22px;
  transition: background .2s;
}
.ds-why-card:hover { background: #222; }
.ds-why-icon {
  width: 44px; height: 44px; border-radius: 14px;
  background: rgba(138,173,127,.15);
  border: 1px solid rgba(138,173,127,.25);
  color: var(--sage); font-size: 18px;
  display: flex; align-items: center; justify-content: center;
  margin-bottom: 16px;
}
.ds-why-card h3 {
  color: #fff; font-size: 15px; font-weight: 700; margin-bottom: 8px;
}
.ds-why-card p { color: rgba(255,255,255,.45); font-size: 13px; line-height: 1.65; }

/* ── BEST SELLER ── */
.ds-best-section { padding: 64px 0; background: var(--cream); }
.ds-best-scroll {
  display: flex; gap: 16px; overflow-x: auto;
  scroll-snap-type: x mandatory;
  padding: 24px 0 8px; scrollbar-width: none;
}
.ds-best-scroll::-webkit-scrollbar { display: none; }

/* ── PRODUCT GRID ── */
.ds-products-section {
  padding: 64px 0;
  background: var(--white);
}
.ds-toolbar {
  display: flex; flex-direction: column; gap: 12px;
  margin: 24px 0 20px;
}
.ds-search-wrap { position: relative; }
.ds-search-wrap i {
  position: absolute; left: 16px; top: 50%;
  transform: translateY(-50%); color: var(--muted); font-size: 13px;
}
.ds-search {
  width: 100%; min-height: 48px;
  padding: 0 16px 0 44px;
  border-radius: 999px;
  border: 1.5px solid var(--line);
  background: var(--cream);
  font-family: var(--font-body);
  font-size: 14px; font-weight: 500;
  outline: none; transition: border-color .2s;
}
.ds-search:focus { border-color: var(--ink); background: #fff; }
.ds-pills { display: flex; gap: 8px; overflow-x: auto; scrollbar-width: none; padding-bottom: 4px; }
.ds-pills::-webkit-scrollbar { display: none; }
.ds-pill {
  min-height: 38px; padding: 0 18px; border-radius: 999px;
  border: 1.5px solid var(--line); background: #fff;
  font-size: 12px; font-weight: 700; color: var(--muted);
  white-space: nowrap; transition: all .18s;
}
.ds-pill:hover { border-color: var(--ink); color: var(--ink); }
.ds-pill.active { background: var(--ink); color: #fff; border-color: var(--ink); }

.ds-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16px;
}

/* ── PRODUCT CARD ── */
.ds-product-card {
  background: var(--cream);
  border-radius: var(--r-lg);
  overflow: hidden;
  border: 1px solid var(--line);
  transition: transform .22s, box-shadow .22s;
  display: flex; flex-direction: column;
}
.ds-product-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 20px 50px rgba(10,10,10,.1);
}
.ds-product-card.slide-card {
  flex: 0 0 72%;
  scroll-snap-align: start;
}
.ds-prod-media {
  position: relative;
  aspect-ratio: 3/4;
  overflow: hidden; background: #ddd;
}
.ds-prod-media img {
  width: 100%; height: 100%; object-fit: cover;
  transition: transform .3s;
}
.ds-product-card:hover .ds-prod-media img { transform: scale(1.05); }
.ds-prod-badge {
  position: absolute; top: 12px; left: 12px; z-index: 2;
  padding: 5px 10px; border-radius: 999px;
  background: var(--orange); color: #fff;
  font-size: 10px; font-weight: 800; letter-spacing: .04em;
}
.ds-prod-fav {
  position: absolute; top: 12px; right: 12px; z-index: 2;
  width: 34px; height: 34px; border-radius: 999px;
  background: rgba(255,255,255,.9); border: 0;
  display: flex; align-items: center; justify-content: center;
  font-size: 13px; color: var(--muted);
  transition: all .2s;
}
.ds-prod-body { padding: 14px; flex: 1; display: flex; flex-direction: column; }
.ds-prod-kat {
  font-size: 10px; font-weight: 800; text-transform: uppercase;
  letter-spacing: .07em; color: var(--sage-dark); margin-bottom: 5px;
}
.ds-prod-name {
  font-family: var(--font-display);
  font-size: 14px; font-weight: 700;
  line-height: 1.25; letter-spacing: -.02em;
  display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
  min-height: 35px; margin-bottom: 8px;
}
.ds-prod-meta {
  font-size: 11px; color: var(--muted); line-height: 1.7; margin-bottom: 10px;
}
.ds-prod-price {
  margin-top: auto;
  display: flex; align-items: baseline; gap: 6px; flex-wrap: wrap;
}
.ds-price { font-family: var(--font-display); font-size: 16px; font-weight: 800; color: var(--ink); }
.ds-price-old { font-size: 11px; color: #bbb; text-decoration: line-through; font-weight: 600; }
.ds-prod-actions {
  display: grid; grid-template-columns: 38px 1fr; gap: 8px;
  margin-top: 12px;
}
.ds-detail-btn {
  width: 38px; height: 38px; border-radius: 12px;
  border: 1.5px solid var(--line); background: #fff;
  color: var(--muted); font-size: 13px;
  display: flex; align-items: center; justify-content: center;
  transition: all .18s;
}
.ds-detail-btn:hover { border-color: var(--ink); color: var(--ink); }
.ds-buy-btn {
  min-height: 38px; border-radius: 12px; border: 0;
  background: var(--ink); color: #fff;
  font-size: 12px; font-weight: 700; font-family: var(--font-body);
  letter-spacing: .02em; transition: background .18s;
}
.ds-buy-btn:hover { background: var(--ink-soft); }

.ds-empty-state {
  grid-column: 1 / -1;
  padding: 48px 24px; text-align: center;
  border: 1.5px dashed var(--line);
  border-radius: var(--r-lg);
  color: var(--muted); font-size: 14px;
}

.ds-load-wrap { display: flex; justify-content: center; margin-top: 32px; }

/* ── HOW TO ORDER ── */
.ds-order-section {
  padding: 64px 0;
  background: var(--cream);
}
.ds-order-grid { display: grid; gap: 16px; margin-top: 36px; }
.ds-step {
  background: #fff;
  border-radius: var(--r-lg);
  padding: 24px;
  border: 1px solid var(--line);
  display: flex; align-items: flex-start; gap: 18px;
}
.ds-step-num {
  font-family: var(--font-display);
  font-size: 48px; font-weight: 800; letter-spacing: -.05em;
  color: var(--line); line-height: 1; flex: 0 0 auto;
  width: 50px;
}
.ds-step h3 { font-size: 16px; font-weight: 700; margin-bottom: 6px; }
.ds-step p { font-size: 13px; color: var(--muted); line-height: 1.65; }

/* ── LOCATION ── */
.ds-location-section { padding: 64px 0; background: var(--white); }
.ds-loc-grid { display: grid; gap: 14px; margin-top: 32px; }
.ds-loc-item {
  background: var(--cream);
  border: 1px solid var(--line);
  border-radius: var(--r-md);
  padding: 20px; display: flex; gap: 16px; align-items: flex-start;
}
.ds-loc-icon {
  width: 46px; height: 46px; border-radius: 14px;
  background: var(--sage-pale); color: var(--sage-dark);
  display: flex; align-items: center; justify-content: center;
  font-size: 17px; flex: 0 0 auto;
}
.ds-loc-item h3 { font-size: 14px; font-weight: 700; margin-bottom: 5px; }
.ds-loc-item p { font-size: 13px; color: var(--muted); line-height: 1.65; }

/* ── TESTIMONIALS ── */
.ds-testi-section { padding: 64px 0; background: var(--cream); }
.ds-testi-grid { display: grid; gap: 14px; margin-top: 32px; }
.ds-testi-card {
  background: #fff; border: 1px solid var(--line);
  border-radius: var(--r-lg); padding: 22px;
}
.ds-stars { color: #f59e0b; font-size: 12px; margin-bottom: 10px; }
.ds-testi-card h3 { font-size: 15px; font-weight: 700; margin-bottom: 6px; }
.ds-testi-card p { font-size: 13px; color: var(--muted); line-height: 1.7; }

/* ── FOOTER ── */
.ds-footer {
  background: var(--ink);
  border-radius: 40px 40px 0 0;
  padding: 56px 0 100px;
  margin-top: 0;
}
.ds-footer-grid { display: grid; gap: 40px; }
.ds-footer-logo {
  font-family: var(--font-display);
  font-size: 36px; font-weight: 800; letter-spacing: -.06em;
  color: #fff; margin-bottom: 16px;
}
.ds-footer-logo em { color: var(--sage); font-style: normal; }
.ds-footer p { color: rgba(255,255,255,.45); font-size: 14px; line-height: 1.8; }
.ds-footer-ctas { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 24px; }
.ds-footer-links { display: grid; gap: 10px; margin-top: 12px; }
.ds-footer-links h4 { color: rgba(255,255,255,.3); font-size: 10px; letter-spacing: .1em; text-transform: uppercase; margin-bottom: 8px; }
.ds-footer-links a { color: rgba(255,255,255,.6); font-size: 14px; font-weight: 500; transition: color .18s; }
.ds-footer-links a:hover { color: #fff; }
.ds-socials { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 24px; }
.ds-social-btn {
  width: 42px; height: 42px; border-radius: 999px;
  border: 1px solid rgba(255,255,255,.12);
  background: transparent; color: rgba(255,255,255,.55);
  display: flex; align-items: center; justify-content: center;
  font-size: 15px; transition: all .2s;
}
.ds-social-btn:hover { background: #fff; color: var(--ink); border-color: #fff; }
.ds-copy { margin-top: 20px !important; font-size: 11px !important; color: rgba(255,255,255,.2) !important; }

/* ── STICKY MOBILE BAR ── */
.ds-sticky {
  position: fixed; left: 12px; right: 12px; bottom: 12px; z-index: 100;
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 8px; padding: 8px;
  background: rgba(10,10,10,.9);
  backdrop-filter: blur(16px);
  border-radius: 22px;
  border: 1px solid rgba(255,255,255,.08);
}
.ds-sticky a {
  min-height: 46px; border-radius: 14px;
  display: flex; align-items: center; justify-content: center;
  gap: 8px; font-size: 13px; font-weight: 700; color: #fff !important;
  transition: opacity .2s;
}
.ds-sticky a:hover { opacity: .85; }
.ds-sticky .sp { background: var(--orange); }
.ds-sticky .wa { background: var(--wa); }

/* ── LOADING ── */
.ds-loading {
  position: fixed; inset: 0; z-index: 999;
  background: var(--cream);
  display: flex; align-items: center; justify-content: center;
  flex-direction: column; gap: 14px;
  font-family: var(--font-display);
}
.ds-spinner {
  width: 40px; height: 40px;
  border: 2.5px solid var(--line);
  border-top-color: var(--sage);
  border-radius: 999px;
  animation: spin .8s linear infinite;
}
.ds-loading p {
  font-size: 13px; font-weight: 600; color: var(--muted);
  letter-spacing: .03em;
}
@keyframes spin { to { transform: rotate(360deg); } }

/* ── MODAL ── */
.ds-modal {
  position: fixed; inset: 0; z-index: 200;
  display: none; align-items: flex-end; justify-content: center;
  padding: 0;
  background: rgba(0,0,0,.6);
  backdrop-filter: blur(4px);
}
.ds-modal.show { display: flex; }
.ds-modal-card {
  width: 100%; max-height: 90vh;
  overflow-y: auto;
  background: #fff;
  border-radius: 32px 32px 0 0;
  box-shadow: 0 -20px 80px rgba(0,0,0,.2);
  animation: slideUp .3s ease;
}
@keyframes slideUp { from { transform: translateY(60px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }
.ds-modal-img {
  aspect-ratio: 16/9;
  background: #eee; overflow: hidden;
}
.ds-modal-img img { width: 100%; height: 100%; object-fit: cover; }
.ds-modal-body { padding: 24px; }
.ds-modal-head { display: flex; align-items: flex-start; justify-content: space-between; gap: 14px; }
.ds-modal-close {
  width: 38px; height: 38px; border-radius: 999px;
  border: 1.5px solid var(--line); background: #fff;
  font-size: 14px; color: var(--muted);
  display: flex; align-items: center; justify-content: center;
