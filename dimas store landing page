<script>
(function () {
  const DEFAULTS = {
    store_name: 'Dimas Store',
    store_tagline: 'Outfit Casual & Streetwear Kekinian',
    store_description: 'Pilihan baju nyaman, stylish, dan mudah dipakai untuk aktivitas harian.',
    shopee_toko: '', instagram: '', tiktok: '', whatsapp: '',
    whatsapp_number: '', whatsapp_text: 'Halo Dimas Store, saya mau tanya produk.',
    linktree: '',
    hero_image: 'https://images.unsplash.com/photo-1523381294911-8d3cead13475?auto=format&fit=crop&w=1200&q=80',
    logo_text: 'DIMASSTORE'
  };

  const CATEGORY_IMAGES = {
    'Kaos Oversize': 'https://images.unsplash.com/photo-1583743814966-8936f5b7be1a?auto=format&fit=crop&w=500&q=80',
    'Kemeja Casual': 'https://images.unsplash.com/photo-1596755094514-f87e32f85f98?auto=format&fit=crop&w=500&q=80',
    'Hoodie': 'https://images.unsplash.com/photo-1556821840-3a63f95609a7?auto=format&fit=crop&w=500&q=80',
    'Crewneck': 'https://images.unsplash.com/photo-1620799140408-edc6dcb6d633?auto=format&fit=crop&w=500&q=80',
    'Celana Casual': 'https://images.unsplash.com/photo-1624378439575-d8705ad7ae80?auto=format&fit=crop&w=500&q=80'
  };

  const state = {
    settings: Object.assign({}, DEFAULTS),
    products: [], activeCategory: 'Semua', search: '', showAll: false
  };

  const config = window.DIMAS_STORE_CONFIG || {};
  const apiUrl = String(config.APPS_SCRIPT_URL || '').trim();

  function rupiah(v) { return 'Rp ' + Number(v || 0).toLocaleString('id-ID'); }
  function clean(v, fb = '') { return (v === undefined || v === null || v === '') ? fb : v; }
  function esc(v) {
    return String(v || '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;').replace(/'/g,'&#039;');
  }
  function nk(v) { return String(v||'').toLowerCase().replace(/[^a-z0-9]/g,''); }
  function readAny(obj, keys, fb = '') {
    if (!obj) return fb;
    const lu = {}; Object.keys(obj).forEach(k => { lu[k]=obj[k]; lu[nk(k)]=obj[k]; });
    for (let k of keys) { const d=lu[k], n=lu[nk(k)]; if (d!==undefined&&d!==null&&String(d).trim()!=='') return d; if (n!==undefined&&n!==null&&String(n).trim()!=='') return n; }
    return fb;
  }
  function isPlaceholder(v) { const t=String(v||'').toLowerCase().trim(); return !t||t==='#'||t.includes('isi_')||t.includes('username')||t.includes('link-produk'); }
  function cleanUrl(v, fb = '') {
    let t = String(v||'').trim(); if (isPlaceholder(t)) return fb;
    if (/^https?:\/\//i.test(t)) return t;
    if (/^(shopee\.co\.id|instagram\.com|www\.instagram\.com|tiktok\.com|www\.tiktok\.com|linktr\.ee|wa\.me)\//i.test(t)) return 'https://'+t;
    return t||fb;
  }
  function makeWaLink(num, msg) {
    let d = String(num||'').replace(/\D/g,''); if (!d) return '';
    if (d[0]==='0') d='62'+d.slice(1); if (d[0]==='8') d='62'+d;
    return 'https://wa.me/'+d+'?text='+encodeURIComponent(String(msg||DEFAULTS.whatsapp_text));
  }

  function normalizeSettings(raw) {
    raw = raw||{};
    const waD = cleanUrl(readAny(raw,['whatsapp','WhatsApp','Whatsapp','WA_Link'],''));
    const waNum = readAny(raw,['whatsapp_number','WhatsApp_Number','Nomor_WhatsApp','Nomor WA','No_WA'],'');
    const waTxt = readAny(raw,['whatsapp_text','WhatsApp_Text','Pesan_WhatsApp'],DEFAULTS.whatsapp_text);
    const waBuilt = makeWaLink(waNum, waTxt);
    return {
      store_name: String(readAny(raw,['store_name','Store_Name','Nama_Toko'],DEFAULTS.store_name)),
      store_tagline: String(readAny(raw,['store_tagline','Store_Tagline','Tagline'],DEFAULTS.store_tagline)),
      store_description: String(readAny(raw,['store_description','Store_Description','Deskripsi_Toko'],DEFAULTS.store_description)),
      shopee_toko: cleanUrl(readAny(raw,['shopee_toko','Shopee_Toko','Shopee','Link_Shopee'],''),DEFAULTS.shopee_toko),
      instagram: cleanUrl(readAny(raw,['instagram','Instagram','IG'],''),DEFAULTS.instagram),
      tiktok: cleanUrl(readAny(raw,['tiktok','TikTok','Tiktok'],''),DEFAULTS.tiktok),
      whatsapp_number: String(waNum||''), whatsapp_text: String(waTxt||DEFAULTS.whatsapp_text),
      whatsapp: waBuilt||waD||'',
      linktree: cleanUrl(readAny(raw,['linktree','Linktree','Link_Tree'],''),DEFAULTS.linktree),
      hero_image: cleanUrl(readAny(raw,['hero_image','Hero_Image','Gambar_Hero'],''),DEFAULTS.hero_image),
      logo_text: String(readAny(raw,['logo_text','Logo_Text','Logo'],DEFAULTS.logo_text))
    };
  }

  function normalizeProduct(raw, idx) {
    raw = raw||{};
    const link = cleanUrl(readAny(raw,['link_shopee','Link_Shopee','Shopee','shopee'],''),state.settings.shopee_toko);
    return {
      id: String(readAny(raw,['id','ID'],'') || 'p_'+idx),
      nama_produk: String(readAny(raw,['nama_produk','Nama_Produk','name'],'Produk Dimas Store')),
      slug: String(readAny(raw,['slug','Slug'],'')),
      kategori: String(readAny(raw,['kategori','Kategori'],'Produk')),
      harga: Number(readAny(raw,['harga','Harga'],0)||0),
      harga_coret: Number(readAny(raw,['harga_coret','Harga_Coret'],0)||0),
      deskripsi: String(readAny(raw,['deskripsi','Deskripsi'],'')),
      ukuran: String(readAny(raw,['ukuran','Ukuran','Size'],'')),
      warna: String(readAny(raw,['warna','Warna','Color'],'')),
      label: String(readAny(raw,['label','Label'],'')),
      best_seller: ['true','ya','yes','1','aktif','best'].includes(String(readAny(raw,['best_seller','Best_Seller'],'')).toLowerCase()),
      foto_1: cleanUrl(readAny(raw,['foto_1','Foto_1','image'],'')),
      foto_2: cleanUrl(readAny(raw,['foto_2','Foto_2'],'')),
      foto_3: cleanUrl(readAny(raw,['foto_3','Foto_3'],'')),
      link_shopee: link,
      status: String(readAny(raw,['status','Status'],'Aktif')),
      urutan: Number(readAny(raw,['urutan','Urutan'],9999)||9999),
      _key: ''
    };
  }

  function jsonp(url) {
    return new Promise((res, rej) => {
      const name = 'dsCallback_'+Date.now()+'_'+Math.floor(Math.random()*999999);
      const script = document.createElement('script');
      const sep = url.includes('?')?'&':'?';
      script.src = url+sep+'callback='+encodeURIComponent(name)+'&cache='+Date.now();
      const t = setTimeout(() => { cleanup(); rej(new Error('JSONP timeout')); }, 30000);
      const cleanup = () => { try{delete window[name];}catch(e){window[name]=undefined;} script.parentNode&&script.parentNode.removeChild(script); };
      window[name] = d => { clearTimeout(t); cleanup(); res(d); };
      script.onerror = () => { clearTimeout(t); cleanup(); rej(new Error('Script JSONP gagal')); };
      script.async = true;
      (document.body||document.documentElement).appendChild(script);
    });
  }

  function productImg(p) {
    return p.foto_1||p.foto_2||p.foto_3||'https://images.unsplash.com/photo-1523381294911-8d3cead13475?auto=format&fit=crop&w=900&q=80';
  }
  function productLink(p) { return cleanUrl(p.link_shopee, state.settings.shopee_toko||''); }

  function getCategories() {
    return ['Semua', ...Array.from(new Set(state.products.map(p=>p.kategori).filter(Boolean)))];
  }

  function filteredProducts() {
    const kw = state.search.trim().toLowerCase();
    return state.products.filter(p => {
      const catOk = state.activeCategory==='Semua'||p.kategori===state.activeCategory;
      const txt = [p.nama_produk,p.kategori,p.ukuran,p.warna,p.deskripsi].join(' ').toLowerCase();
      return catOk && (!kw||txt.includes(kw));
    });
  }

  function resolveLink(key) {
    if (key==='whatsapp') { return cleanUrl(state.settings.whatsapp,'')||makeWaLink(state.settings.whatsapp_number, state.settings.whatsapp_text); }
    return cleanUrl(state.settings[key],'');
  }

  function setStoreLinks() {
    document.querySelectorAll('#ds-app [data-store-link]').forEach(el => {
      const key = el.getAttribute('data-store-link');
      const href = resolveLink(key);
      el.onclick = null;
      if (href) {
        el.href = href; el.target = '_blank'; el.rel = 'noopener noreferrer';
        el.style.opacity = ''; el.style.pointerEvents = '';
      } else {
        el.href = 'javascript:void(0)'; el.removeAttribute('target'); el.removeAttribute('rel');
        el.style.opacity = '.5';
        el.onclick = e => e.preventDefault();
      }
    });
  }

  function renderSettings() {
    const s = state.settings;
    const titleEl = document.querySelector('#ds-app [data-store-title]');
    const descEl = document.querySelector('#ds-app [data-store-description]');
    const heroEl = document.querySelector('#ds-app [data-store-hero]');
    const logoEl = document.querySelector('#ds-app [data-store-logo]');
    const statEl = document.getElementById('dsStatProduk');
    if (titleEl) titleEl.textContent = s.store_name||DEFAULTS.store_name;
    if (descEl) descEl.textContent = s.store_description||DEFAULTS.store_description;
    if (heroEl) heroEl.src = s.hero_image||DEFAULTS.hero_image;
    if (statEl) statEl.textContent = state.products.length + '+';
    if (logoEl) {
      const n = String(s.store_name||'Dimas Store').replace(/\s+/g,' ').trim().split(' ');
      logoEl.innerHTML = esc(n[0].toUpperCase())+'<em>'+esc((n.slice(1).join('')||'STORE').toUpperCase())+'</em>';
    }
    setStoreLinks();
  }

  function renderCategoryCards() {
    const wrap = document.getElementById('dsCategoryCards');
    if (!wrap) return;
    const cats = getCategories().filter(c=>c!=='Semua');
    wrap.innerHTML = cats.length ? cats.map(cat => {
      const sample = state.products.find(p=>p.kategori===cat);
      const img = CATEGORY_IMAGES[cat]||productImg(sample||{});
      return `<div class="ds-cat-item" data-set-cat="${esc(cat)}"><div class="ds-cat-img"><img src="${esc(img)}" alt="${esc(cat)}" loading="lazy"></div><p class="ds-cat-name">${esc(cat)}</p></div>`;
    }).join('') : '';
    wrap.querySelectorAll('[data-set-cat]').forEach(el => {
      el.addEventListener('click', function() {
        state.activeCategory = this.getAttribute('data-set-cat');
        state.showAll = true; renderProductArea();
        document.getElementById('produk')?.scrollIntoView({behavior:'smooth'});
      });
    });
  }

  function renderPills() {
    const wrap = document.getElementById('dsCategoryPills');
    if (!wrap) return;
    wrap.innerHTML = getCategories().map(cat =>
      `<button type="button" class="ds-pill${cat===state.activeCategory?' active':''}" data-cat="${esc(cat)}">${esc(cat)}</button>`
    ).join('');
    wrap.querySelectorAll('[data-cat]').forEach(btn => {
      btn.addEventListener('click', function() { state.activeCategory=this.getAttribute('data-cat'); state.showAll=false; renderProductArea(); });
    });
  }

  function productCardHTML(p, mode='grid') {
    const label = clean(p.label);
    const oldPrice = Number(p.harga_coret||0)>0 ? `<span class="ds-price-old">${rupiah(p.harga_coret)}</span>` : '';
    const slideClass = mode==='slide' ? ' slide-card' : '';
    return `
      <article class="ds-product-card${slideClass}">
        <div class="ds-prod-media">
          ${label ? `<span class="ds-prod-badge">${esc(label)}</span>` : ''}
          <img src="${esc(productImg(p))}" alt="${esc(p.nama_produk)}" loading="lazy">
        </div>
        <div class="ds-prod-body">
          <p class="ds-prod-kat">${esc(clean(p.kategori,'Produk'))}</p>
          <h3 class="ds-prod-name">${esc(clean(p.nama_produk,'Produk'))}</h3>
          <div class="ds-prod-meta">
            <span>Ukuran: ${esc(clean(p.ukuran,'-'))}</span>
            <span>Warna: ${esc(clean(p.warna,'-'))}</span>
          </div>
          <div class="ds-prod-price"><span class="ds-price">${rupiah(p.harga)}</span>${oldPrice}</div>
          <div class="ds-prod-actions">
            <button type="button" class="ds-detail-btn" data-pkey="${esc(p._key)}" aria-label="Detail"><i class="fa-solid fa-eye"></i></button>
            <a class="ds-buy-btn" href="${esc(productLink(p))}" target="_blank" rel="noopener noreferrer">Beli di Shopee</a>
          </div>
        </div>
      </article>`;
  }

  function bindDetailBtns(scope) {
    scope.querySelectorAll('[data-pkey]').forEach(btn => {
      btn.addEventListener('click', function() {
        const p = state.products.find(x=>String(x._key)===String(this.getAttribute('data-pkey')));
        if (p) openModal(p);
      });
    });
  }

  function renderBestSeller() {
    const wrap = document.getElementById('dsBestSeller');
    if (!wrap) return;
    const best = state.products.filter(p=>p.best_seller).slice(0,10);
    const data = best.length ? best : state.products.slice(0,8);
    wrap.innerHTML = data.length ? data.map(p=>productCardHTML(p,'slide')).join('') : '';
    bindDetailBtns(wrap);
  }

  function renderProducts() {
    const grid = document.getElementById('dsProductGrid');
    const btn = document.getElementById('dsLoadMore');
    if (!grid) return;
    const data = filteredProducts();
    const shown = state.showAll ? data : data.slice(0,8);
    grid.innerHTML = shown.length ? shown.map(p=>productCardHTML(p,'grid')).join('') :
      '<div class="ds-empty-state">Produk tidak ditemukan. Coba kata kunci lain.</div>';
    bindDetailBtns(grid);
    if (btn) { btn.style.display = data.length>8?'':'none'; btn.textContent = state.showAll?'Tampilkan Lebih Sedikit':'Tampilkan Semua Produk'; }
  }

  function renderProductArea() { renderPills(); renderProducts(); }

  function openModal(p) {
    const modal = document.getElementById('dsProductModal');
    if (!modal) return;
    document.getElementById('dsModalImage').src = productImg(p);
    document.getElementById('dsModalCategory').textContent = p.kategori||'Produk';
    document.getElementById('dsModalTitle').textContent = p.nama_produk||'Produk Dimas Store';
    document.getElementById('dsModalDesc').textContent = p.deskripsi||'Detail bisa dicek langsung di Shopee.';
    document.getElementById('dsModalPrice').textContent = rupiah(p.harga);
    document.getElementById('dsModalSize').textContent = p.ukuran||'-';
    document.getElementById('dsModalColor').textContent = p.warna||'-';
    document.getElementById('dsModalShopee').href = productLink(p);
    modal.classList.add('show'); modal.setAttribute('aria-hidden','false');
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    const modal = document.getElementById('dsProductModal');
    if (!modal) return;
    modal.classList.remove('show'); modal.setAttribute('aria-hidden','true');
    document.body.style.overflow = '';
  }

  function bindEvents() {
    const search = document.getElementById('dsSearchInput');
    const loadMore = document.getElementById('dsLoadMore');
    const closeBtn = document.getElementById('dsModalClose');
    const modal = document.getElementById('dsProductModal');
    if (search) search.addEventListener('input', function() { state.search=this.value; state.showAll=false; renderProducts(); });
    if (loadMore) loadMore.addEventListener('click', () => { state.showAll=!state.showAll; renderProducts(); });
    if (closeBtn) closeBtn.addEventListener('click', closeModal);
    if (modal) modal.addEventListener('click', e => { if (e.target===modal) closeModal(); });
    document.addEventListener('keydown', e => { if (e.key==='Escape') closeModal(); });
  }

  function resolvePayload(data) {
    const payload = data||{};
    if (payload.ok===false) throw new Error(payload.message||'API error');
    const sRaw = payload.settings||payload.data?.settings||(payload.shopee_toko||payload.Store_Name?payload:{});
    const pRaw = Array.isArray(payload.products)?payload.products:(Array.isArray(payload.data?.products)?payload.data.products:(Array.isArray(payload)?payload:[]));
    state.settings = Object.assign({},DEFAULTS,normalizeSettings(sRaw));
    if (!state.settings.whatsapp&&state.settings.whatsapp_number) state.settings.whatsapp = makeWaLink(state.settings.whatsapp_number,state.settings.whatsapp_text);
    state.products = pRaw.map((item,i) => {
      const p = normalizeProduct(item,i);
      p._key = p.id||p.slug||'p_'+i;
      if (!p.id) p.id = p._key;
      return p;
    }).filter(p=>String(p.status||'Aktif').toLowerCase()==='aktif');
  }

  function renderAll() { renderSettings(); renderCategoryCards(); renderBestSeller(); renderProductArea(); }

  async function init() {
    const loading = document.getElementById('dsLoading');
    bindEvents();
    try {
      if (!apiUrl||apiUrl.includes('ISI_')) { state.settings=Object.assign({},DEFAULTS); state.products=[]; renderAll(); return; }
      const sep = apiUrl.includes('?')?'&':'?';
      const data = await jsonp(apiUrl+sep+'action=store');
      resolvePayload(data); renderAll();
    } catch(err) {
      console.error('Dimas Store error:', err);
      state.settings=Object.assign({},DEFAULTS); state.products=[]; renderAll();
      const grid = document.getElementById('dsProductGrid');
      if (grid) grid.innerHTML = '<div class="ds-empty-state"><strong>Data belum terbaca dari spreadsheet.</strong><br>Pastikan Apps Script sudah di-deploy dengan akses Anyone.</div>';
    } finally {
      if (loading) loading.remove();
    }
  }

  if (document.readyState==='loading') document.addEventListener('DOMContentLoaded',init,{once:true}); else init();
})();
</script>
